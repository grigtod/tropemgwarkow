    "uuid": "3b86e4c7-2f72-4fbb-91bc-57f0f94da77c",
    "audio_file": "town_3b86e4c7-2f72-4fbb-91bc-57f0f94da77c.mp3"
  },
  "steam_engine": {
    "text": "Before the engine, horses powered drainage. The steam engine allowed deeper mining and reduced flooding risks.",
    "options": [
      {
        "text": "How did it change daily work?",
        "next": "daily_tasks"
